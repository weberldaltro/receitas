---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';

export async function getStaticPaths() {
  const receitas = await getCollection('receitas');
  return receitas.map((receita: any) => ({
    params: { id: receita.id },
    props: { receita },
  }));
}

const { receita } = Astro.props;
const { Content } = await render(receita);
---
<Layout title={`${receita.data.title} - Minha Receita`}>
  <div class="recipe-container container">
    <a href="/" class="back-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
      Voltar para Início
    </a>

    <div class="recipe-header">
      <div class="recipe-hero">
        <img src={receita.data.image} alt={receita.data.title} class="hero-image" />
        <div class="hero-overlay">
          <div class="category-badge">{receita.data.category}</div>
        </div>
      </div>
      
      <div class="recipe-title-section">
        <h1>{receita.data.title}</h1>
        <p class="recipe-description">{receita.data.description}</p>
        
        <div class="recipe-meta-cards">
          <div class="meta-card">
            <div class="icon-circle">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            </div>
            <div>
              <span class="meta-label">Tempo</span>
              <strong class="meta-value">{receita.data.time}</strong>
            </div>
          </div>
          <div class="meta-card">
            <div class="icon-circle">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            </div>
            <div>
              <span class="meta-label">Rendimento</span>
              <strong class="meta-value">{receita.data.portions}</strong>
            </div>
          </div>
        </div>

        <div class="actions">
          <Button variant="primary" class="print-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
            Imprimir Receita
          </Button>
          <Button variant="secondary" class="share-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
            Compartilhar
          </Button>
        </div>
      </div>
    </div>

    <div class="recipe-content-grid">
      <div class="markdown-content">
        <Content />
      </div>
      
      <aside class="recipe-sidebar">
        <div class="sidebar-card">
          <h3>Dica do Chef</h3>
          <p>Para uma experiência ainda mais requintada, utilize ingredientes frescos e evite substituições que alterem o perfil de sabor principal. A qualidade dos temperos faz toda a diferença.</p>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style is:global>
  /* Global Styling for the Markdown Content */
  .markdown-content {
    color: var(--text-dark);
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .markdown-content h2 {
    color: var(--color-primary);
    font-size: 1.75rem;
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-md);
    padding-bottom: 8px;
    border-bottom: 2px solid #F0F0F0;
  }

  .markdown-content ul, 
  .markdown-content ol {
    margin-bottom: var(--spacing-lg);
    padding-left: var(--spacing-md);
  }

  .markdown-content li {
    margin-bottom: var(--spacing-xs);
  }

  .markdown-content strong {
    color: var(--text-dark);
    font-weight: 700;
  }
</style>

<style>
  .recipe-container {
    padding-top: var(--spacing-sm);
    padding-bottom: var(--spacing-xl);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #666;
    font-weight: 500;
    margin-bottom: var(--spacing-md);
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .recipe-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    align-items: center;
    margin-bottom: var(--spacing-xxl);
  }

  @media (max-width: 768px) {
    .recipe-header {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }
  }

  .recipe-hero {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4/3;
    box-shadow: var(--shadow-floating);
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    padding: var(--spacing-md);
  }

  .category-badge {
    display: inline-block;
    background-color: var(--color-primary); /* Podia usar dynamic color aqui via inline styles */
    color: white;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-soft);
  }

  .recipe-title-section h1 {
    font-size: 3rem;
    line-height: 1.1;
    margin-bottom: var(--spacing-sm);
    color: var(--text-dark);
  }

  .recipe-description {
    font-size: 1.2rem;
    color: #666;
    margin-bottom: var(--spacing-lg);
  }

  .recipe-meta-cards {
    display: flex;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
  }

  .meta-card {
    display: flex;
    align-items: center;
    gap: 12px;
    background-color: var(--bg-surface);
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
    border: 1px solid #F0F0F0;
  }

  .icon-circle {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: rgba(242, 93, 39, 0.1);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .meta-label {
    display: block;
    font-size: 0.8rem;
    color: #999;
    text-transform: uppercase;
    font-weight: 600;
  }

  .meta-value {
    display: block;
    font-size: 1.1rem;
    color: var(--text-dark);
  }

  .actions {
    display: flex;
    gap: var(--spacing-sm);
  }

  .recipe-content-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--spacing-xl);
  }

  @media (max-width: 992px) {
    .recipe-content-grid {
      grid-template-columns: 1fr;
    }
  }

  .sidebar-card {
    background-color: var(--bg-surface);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    box-shadow: var(--shadow-soft);
    border-top: 4px solid var(--color-brand);
  }

  .sidebar-card h3 {
    color: var(--color-brand);
    margin-bottom: var(--spacing-sm);
  }
  
  .sidebar-card p {
    color: #555;
    font-size: 0.95rem;
  }
</style>
