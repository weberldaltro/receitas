---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = "Receitas Premium" } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="navbar">
			<div class="container navbar-content">
				<a href="/" class="logo">Minha <span>Receita</span></a>
				<nav class="nav-links">
					<a href="/">Início</a>
					<a href="/categorias">Categorias</a>
				</nav>
			</div>
		</header>
		
		<main class="main-content">
			<slot />
		</main>

		<footer class="footer bg-dark">
			<div class="container footer-content">
				<div class="footer-logo">Minha <span>Receita</span></div>
				<p>&copy; 2026 Receitas Premium. Todos os direitos reservados.</p>
			</div>
		</footer>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		display: flex;
		flex-direction: column;
	}

	.main-content {
		flex: 1;
		padding: var(--spacing-xl) 0;
	}

	.navbar {
		background-color: var(--bg-surface);
		box-shadow: var(--shadow-soft);
		position: sticky;
		top: 0;
		z-index: 100;
		padding: var(--spacing-sm) 0;
	}

	.navbar-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.logo {
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--text-dark);
		display: flex;
		align-items: center;
		gap: 4px;
	}

	.logo span {
		color: var(--color-primary);
	}

	.nav-links {
		display: flex;
		gap: var(--spacing-md);
	}

	.nav-links a {
		font-weight: 500;
		color: var(--text-dark);
	}
	
	.nav-links a:hover {
		color: var(--color-primary);
	}

	.footer {
		padding: var(--spacing-lg) 0;
		margin-top: auto;
	}

	.footer-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-sm);
		text-align: center;
	}

	.footer-logo {
		font-size: 1.5rem;
		font-weight: 700;
	}

	.footer-logo span {
		color: var(--color-primary);
	}

	.footer p {
		color: #999;
		font-size: 0.9rem;
	}
</style>
